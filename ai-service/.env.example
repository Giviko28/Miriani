# AI service configuration. Copy to .env for local overrides (gitignored).
# Local development needs NONE of these — the defaults use the host Ollama for both chat
# and embeddings. These matter only for the cloud deployment (set as env vars on Render).

# --- Providers ---
# LLM_PROVIDER:       ollama (local, default) | groq (cloud)
# EMBEDDING_PROVIDER: ollama (local, default) | local (in-process ONNX all-MiniLM, cloud)
LLM_PROVIDER=ollama
EMBEDDING_PROVIDER=ollama

# --- Groq (only used when LLM_PROVIDER=groq) ---
# Get a free key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# --- Persistence paths (point at a mounted disk in the cloud if one is attached) ---
# CHROMA_PATH=./chroma_store
# DB_CONFIGS_DIR=./db_configs

# --- Retrieval tuning (local ONNX embeddings sit a bit higher than nomic) ---
# RETRIEVAL_MAX_DISTANCE=0.75
